	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/node": "^25.5.2",
		"fastify-tsconfig": "^3.0.0",
		"fastify-type-provider-zod": "^6.1.0",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	}
