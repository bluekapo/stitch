# Stitch Configuration
PORT=3000
LOG_LEVEL=info

# LLM Provider: "llama-server" or "mock" (default: mock for development)
LLM_PROVIDER=mock

# llama-server connection (only used when LLM_PROVIDER=llama-server)
LLAMA_SERVER_URL=http://localhost:8080
LLAMA_MODEL_NAME=qwen3.5-9b
LLM_MAX_RETRIES=2

# Database (default: ./data/stitch.db — directory created automatically)
DATABASE_URL=./data/stitch.db

# STT Provider: "whisper-server" or "mock" (default: mock for development)
STT_PROVIDER=mock

# whisper-server connection (only used when STT_PROVIDER=whisper-server)
# Start whisper-server with: --inference-path "/v1/audio/transcriptions"
WHISPER_SERVER_URL=http://localhost:8081

# Telegram Bot (required for Telegram hub)
TELEGRAM_BOT_TOKEN=
# Your Telegram user ID — only this user can interact with the bot
TELEGRAM_ALLOWED_USER_ID=
